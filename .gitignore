# ──────────────────────────────────────────────
*.swp
*.swo
*~
*.bak
*.orig

# ──────────────────────────────────────────────
# Claude Code
# ──────────────────────────────────────────────
.claude/

# ──────────────────────────────────────────────
# Base de datos compartida (datos personales sensibles)
# ──────────────────────────────────────────────
/storage/
*.sqlite
*.sqlite-journal
*.db
*.db-wal
*.db-shm

# ──────────────────────────────────────────────
# Dependencias genéricas (los subproyectos
# tienen su propio .gitignore con más detalle)
# ──────────────────────────────────────────────
node_modules/
npm-debug.log
yarn-error.log

# ──────────────────────────────────────────────
# Entorno: nunca commitear .env de ningún subproyecto
# ──────────────────────────────────────────────
.env
.env.backup
.env.production
.env.local
infra/.env.team

# ──────────────────────────────────────────────
# Misc legacy
# ──────────────────────────────────────────────
.phpunit.result.cache
Homestead.yaml
Homestead.json
/.vagrant
auth.json
