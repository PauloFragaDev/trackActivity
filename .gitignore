.idea/
.vscode/
.fleet/
.nova/
.zed/
.phpactor.json

# ──────────────────────────────────────────────
# Sistema operativo
# ──────────────────────────────────────────────
.DS_Store
.AppleDouble
.LSOverride
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

# ──────────────────────────────────────────────
