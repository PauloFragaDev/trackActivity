{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "trackActivity",
  "version": "0.1.0",
  "identifier": "com.trackactivity.desktop",
  "build": {
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "trackActivity",
        "url": "http://localhost:8000",
        "width": 1200,
        "height": 800,
        "resizable": true,
        "visible": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["deb", "appimage"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
