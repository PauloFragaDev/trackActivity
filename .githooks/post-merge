#!/usr/bin/env bash
# Recompila los assets del dashboard tras un merge/pull si cambió algo de front.
#
# public/build (CSS/JS compilados por Vite) está gitignorado, así que mergear
# NO actualiza la UI compilada. Sin esto, tras un pull la web/desktop muestra
# CSS viejo hasta que recuerdas hacer `npm run build`. Este hook lo hace solo.
#
# Activación (una vez por clon):  git config core.hooksPath .githooks
set -e
root="$(git rev-parse --show-toplevel)"
changed="$(git diff-tree -r --name-only --no-commit-id ORIG_HEAD HEAD 2>/dev/null || true)"

if echo "$changed" | grep -qE '^dashboard/(resources/|package(-lock)?\.json|vite\.config|tailwind\.config|postcss\.config)'; then
    echo "[post-merge] Cambios de front detectados → recompilando assets (npm run build)…"
    ( cd "$root/dashboard" && npm run build ) && echo "[post-merge] Assets actualizados."
fi
