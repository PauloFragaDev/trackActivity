APP_NAME=trackActivity
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_TIMEZONE=UTC
APP_URL=http://127.0.0.1:8100

APP_LOCALE=es
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=es_ES

APP_MAINTENANCE_DRIVER=file

PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# ──────────────────────────────────────────────
# Base de datos compartida con el daemon Python
# Ajusta esta ruta a tu $HOME real.
# ──────────────────────────────────────────────
DB_CONNECTION=sqlite
DB_DATABASE=/var/www/html/trackActivity/storage/activity.db
DB_FOREIGN_KEYS=true

# ──────────────────────────────────────────────
# Sesión / cache / queue: archivo, sin BBDD
# ──────────────────────────────────────────────
SESSION_DRIVER=file
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=sync

CACHE_STORE=file
CACHE_PREFIX=

# ──────────────────────────────────────────────
# trackActivity
# ──────────────────────────────────────────────
TRACKER_BLOCK_MINUTES=15
TRACKER_IDLE_GAP_MINUTES=5
TRACKER_DISPLAY_TIMEZONE=Europe/Madrid

TRACKER_CONFIDENCE_HIGH=0.65
TRACKER_CONFIDENCE_MEDIUM=0.35

TRACKER_SUMMARY_ENGINE=template
TRACKER_SUMMARY_LOCALE=es

MAIL_MAILER=log

# ──────────────────────────────────────────────
# API REST (Bearer token estático para clientes
# como la extensión code-kanban). Generar con
# `php artisan tinker --execute='echo bin2hex(random_bytes(32));'`
# y poner el mismo valor aquí y en el cliente.
# ──────────────────────────────────────────────
API_TOKEN=

VITE_APP_NAME="${APP_NAME}"
