# infra/.env.team.example
#
# Plantilla de las variables que necesita el contenedor `app` del Kanban
# público del equipo (infra/docker-compose.yml -> env_file: .env.team).
#
# Copia este fichero a `infra/.env.team` (NUNCA lo commitees, ya está en
# .gitignore) y rellena los valores reales antes de `docker compose up -d`.
#
# ──────────────────────────────────────────────
# Núcleo de la aplicación
# ──────────────────────────────────────────────
APP_NAME=trackActivity
APP_ENV=production
APP_DEBUG=false
APP_TIMEZONE=UTC
APP_URL=https://kanban.tudominio.com

# Generar con: php artisan key:generate --show
APP_KEY=

# Activa el modo "solo Kanban de equipo": login obligatorio, resto de rutas
# inalcanzables (ver App\Http\Middleware\RestrictToTeamOnly).
APP_MODE=team_only

# ──────────────────────────────────────────────
# Sesión / cache: SIN tabla `sessions`/`cache` migrada en este proyecto.
# Laravel 11 usa `database` por defecto si estas dos no se fijan
# explícitamente, lo que provocaría un 500 en el primer login. Usa `file`.
# ──────────────────────────────────────────────
SESSION_DRIVER=file
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

CACHE_STORE=file
CACHE_PREFIX=

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=sync

# ──────────────────────────────────────────────
# Base de datos local del contenedor (sqlite, según Dockerfile/start.sh).
# NO guarda nada crítico: ni `users` (login) ni `team_members`/`tasks` viven
# aquí, todo eso está en Supabase. Este sqlite solo guarda ajustes internos
# de esta instalación (Setting), así que perderlo en un redeploy es
# inofensivo — no hace falta volumen persistente para él.
# ──────────────────────────────────────────────
DB_CONNECTION=sqlite
DB_DATABASE=/app/database/database.sqlite
DB_FOREIGN_KEYS=true

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=error

MAIL_MAILER=log

# ──────────────────────────────────────────────
# Supabase (Kanban de equipo)
# Mismos valores ya usados por el .env local del dashboard.
# Obtén estos valores en: Supabase Dashboard → Settings → Database
# ──────────────────────────────────────────────
SUPABASE_DB_HOST=db.<project-ref>.supabase.co
SUPABASE_DB_PORT=5432
SUPABASE_DB_DATABASE=postgres
SUPABASE_DB_USERNAME=postgres
SUPABASE_DB_PASSWORD=your-db-password
SUPABASE_DB_SSLMODE=require

# Clave pública (anon) — se pasa al frontend JS para Realtime
SUPABASE_ANON_KEY=your-anon-key

# Clave privada (service_role) — solo en servidor, nunca al frontend
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# URL del proyecto Supabase (para el cliente JS)
SUPABASE_URL=https://<project-ref>.supabase.co

# ──────────────────────────────────────────────
# Cuentas de login del Kanban público (obligatorio en team_only).
# Rellena hasta 3 slots. team_member_id = id del TeamMember en Supabase.
# Tras rellenarlos, corre dentro del contenedor:
#   docker compose exec app php artisan db:seed --class=TeamUsersSeeder
# ──────────────────────────────────────────────
TEAM_USER_1_EMAIL=
TEAM_USER_1_PASSWORD=
TEAM_USER_1_NAME=
TEAM_USER_1_MEMBER_ID=

TEAM_USER_2_EMAIL=
TEAM_USER_2_PASSWORD=
TEAM_USER_2_NAME=
TEAM_USER_2_MEMBER_ID=

TEAM_USER_3_EMAIL=
TEAM_USER_3_PASSWORD=
TEAM_USER_3_NAME=
TEAM_USER_3_MEMBER_ID=
